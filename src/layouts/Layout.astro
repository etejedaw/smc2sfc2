---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="description" content="Batch convert SNES ROM formats between .smc and .sfc entirely in the browser. No uploads, no backend." />
		<meta name="theme-color" content="#493580" />
		<meta property="og:title" content="smc2sfc2 — SNES ROM Converter" />
		<meta property="og:description" content="Batch convert SNES ROM formats between .smc and .sfc entirely in the browser." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://smc2sfc2.etejeda.dev" />
		<meta property="og:image" content="https://smc2sfc2.etejeda.dev/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500" rel="stylesheet" />
		<title>{title}</title>
		<script is:inline>
			if ("serviceWorker" in navigator) {
				navigator.serviceWorker.register("/sw.js");
			}
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		background-color: #bdbcc0;
		height: 100%;
		font-family: 'Roboto', sans-serif;
	}

	body {
		background: url("/gamepad.svg") no-repeat center center fixed;
		background-size: contain;
		height: 100%;
		margin: 0;
	}
</style>
