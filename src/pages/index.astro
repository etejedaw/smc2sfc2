---
import Layout from "../layouts/Layout.astro";
import Toolbar from "../components/Toolbar.astro";
import ProgressBar from "../components/ProgressBar.astro";
import RomCard from "../components/RomCard.astro";
import Snackbar from "../components/Snackbar.astro";
import Footer from "../components/Footer.astro";
import DropZone from "../components/DropZone.astro";
---

<Layout title="SNES ROM Converter: smc to sfc">
	<Toolbar />
	<ProgressBar />
	<main>
		<p class="format-info">
			<strong>.sfc</strong> is the raw ROM data. <strong>.smc</strong> adds a 512-byte header from old SNES copier devices. This tool converts between both formats.
		</p>
		<div class="rom-counter" id="rom-counter" aria-live="polite"></div>
		<div class="rom-list" id="rom-list" role="list" aria-label="Loaded ROMs"></div>
	</main>
	<RomCard />
	<Snackbar />
	<DropZone />
	<Footer />
	<script src="../scripts/app.ts"></script>
</Layout>

<style>
	.format-info {
		text-align: center;
		padding: 12px 16px 0;
		font-size: 13px;
		color: rgba(0, 0, 0, 0.45);
		max-width: 480px;
		margin: 0 auto;
	}

	.rom-counter {
		text-align: center;
		padding: 8px;
		font-size: 14px;
		color: rgba(0, 0, 0, 0.54);
		min-height: 14px;
	}
</style>
