---
import FileInput from "./FileInput.astro";
import DownloadMenu from "./DownloadMenu.astro";
---

<div class="toolbar">
	<div class="toolbar-left">
		<svg class="toolbar-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#ffffff">
			<path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm4-3c-.83 0-1.5-.67-1.5-1.5S18.67 9 19.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
		</svg>
		<span class="toolbar-title">smc2sfc2</span>
	</div>
	<div class="toolbar-right">
		<FileInput />
		<DownloadMenu />
	</div>
</div>

<style>
	.toolbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		background-color: #493580;
		height: 56px;
		padding: 0 8px;
	}

	.toolbar-left {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.toolbar-icon {
		width: 24px;
		height: 24px;
		margin: 1em;
	}

	.toolbar-title {
		color: #ffffff;
		font-size: 20px;
		font-weight: 400;
	}

	.toolbar-right {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	@media (max-width: 480px) {
		.toolbar {
			padding: 0 4px;
		}

		.toolbar-icon {
			margin: 0.5em;
		}

		.toolbar-title {
			font-size: 16px;
		}

		.toolbar-right {
			gap: 0;
		}
	}
</style>
